---
import type { DocPage } from "../../lib/docs";

type Props = {
	previousPage?: DocPage;
	nextPage?: DocPage;
};

const { previousPage, nextPage } = Astro.props;
---

{
  (previousPage || nextPage) && (
    <nav
      class:list={[
        "docs-pager",
        previousPage && nextPage
          ? "docs-pager-dual"
          : previousPage
            ? "docs-pager-single-prev"
            : "docs-pager-single-next",
      ]}
      aria-label="Page navigation"
    >
      {previousPage && (
        <a href={previousPage.url} class="docs-pager-link docs-pager-link-prev">
          <span class="docs-pager-kicker">Previous</span>
          <span class="docs-pager-main">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-4 w-4 shrink-0"
              aria-hidden="true"
            >
              <path d="m15 18-6-6 6-6" />
            </svg>
            <span class="docs-pager-title">{previousPage.title}</span>
          </span>
        </a>
      )}

      {nextPage && (
        <a href={nextPage.url} class="docs-pager-link docs-pager-link-next">
          <span class="docs-pager-kicker">Next</span>
          <span class="docs-pager-main">
            <span class="docs-pager-title">{nextPage.title}</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-4 w-4 shrink-0"
              aria-hidden="true"
            >
              <path d="m9 18 6-6-6-6" />
            </svg>
          </span>
        </a>
      )}
    </nav>
  )
}
