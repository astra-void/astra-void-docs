---
import type { DocPage } from "../../lib/docs";

type Props = {
  previousPage?: DocPage;
  nextPage?: DocPage;
};

const { previousPage, nextPage } = Astro.props;
---

{
  (previousPage || nextPage) && (
    <nav class="mt-10 grid gap-3 border-t border-border/70 pt-6 sm:grid-cols-2">
      {previousPage ? (
        <a href={previousPage.url} class="docs-pager-card">
          <span class="docs-pager-label">Previous</span>
          <span class="docs-pager-title">{previousPage.title}</span>
        </a>
      ) : (
        <div class="hidden sm:block" />
      )}

      {nextPage && (
        <a href={nextPage.url} class="docs-pager-card text-left sm:text-right">
          <span class="docs-pager-label">Next</span>
          <span class="docs-pager-title">{nextPage.title}</span>
        </a>
      )}
    </nav>
  )
}
