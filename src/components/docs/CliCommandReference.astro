---
import CodeBlock from "./CodeBlock.astro";
import { Badge } from "../ui/badge";
import { Card } from "../ui/card";
import latticeSnapshot from "../../data/lattice-snapshot.generated";

type CommandName = keyof typeof latticeSnapshot.cli.commands;

type Props = {
  command: CommandName;
  showPhases?: boolean;
};

const { command, showPhases = false } = Astro.props;
const commandMeta = latticeSnapshot.cli.commands[command];
---

<Card className="cli-command-reference grid gap-3.5 p-4">
  <div class="grid gap-2">
    <p class="text-sm font-medium text-muted-foreground">Command</p>
    <p class="text-base font-semibold tracking-[-0.02em] text-foreground">
      <strong>{command}</strong>: {commandMeta.description}
    </p>
  </div>

  <CodeBlock code={`lattice ${commandMeta.signature}`} lang="bash" />

  {
    commandMeta.flags.length > 0 && (
      <div class="grid gap-2">
        <p class="text-sm font-medium text-foreground">Supported flags</p>
        <ul class="flex flex-wrap gap-2">
          {commandMeta.flags.map((flag) => (
            <li>
              <Badge
                variant="outline"
                className="min-h-8 bg-muted/40 px-2.5 py-1 text-sm text-foreground"
              >
                <code>{flag}</code>
              </Badge>
            </li>
          ))}
        </ul>
      </div>
    )
  }

  {
    showPhases && commandMeta.outputPhases.length > 0 && (
      <div class="grid gap-2">
        <p class="text-sm font-medium text-foreground">
          Observed output phases
        </p>
        <ul class="flex flex-wrap gap-2">
          {commandMeta.outputPhases.map((phase) => (
            <li>
              <Badge
                variant="outline"
                className="min-h-8 bg-muted/40 px-2.5 py-1 text-sm text-foreground"
              >
                <code>{phase}</code>
              </Badge>
            </li>
          ))}
        </ul>
      </div>
    )
  }
</Card>
