---
import type { DocsProduct, DocsSectionGroup } from "@/lib/docs"

interface Props {
  sections: DocsSectionGroup[]
  currentPath: string
  product: DocsProduct
}

const { sections, currentPath, product } = Astro.props as Props
---

<div
  id="docs-mobile-nav-panel"
  class="fixed inset-0 z-[100] hidden lg:hidden"
  data-mobile-nav-panel
>
  <div
    class="absolute inset-0 bg-black/40 backdrop-blur-sm"
    data-mobile-nav-overlay
  >
  </div>

  <div
    class="absolute left-0 top-0 flex h-full w-72 max-w-[82%] flex-col overflow-y-auto border-r border-border bg-background shadow-xl"
  >
    <div class="flex h-14 shrink-0 items-center justify-between border-b border-border px-4">
      <a class="text-sm font-semibold text-foreground" href={product.href}>
        {product.title}
      </a>
      <button
        type="button"
        class="inline-flex h-9 w-9 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-muted/50 hover:text-foreground"
        aria-label="Close navigation"
        data-mobile-nav-close
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <nav class="space-y-7 px-4 py-6" aria-label={`${product.title} documentation`}>
      {sections.map((section) => (
        <div>
          <h4 class="mb-2 px-2 text-[0.8rem] font-medium text-muted-foreground">
            {section.label}
          </h4>
          <div class="grid grid-flow-row auto-rows-max text-sm">
            {section.items.map((item) => (
              <a
                aria-current={item.path === currentPath ? "page" : undefined}
                class:list={[
                  "group flex w-full items-center rounded-md px-2 py-1.5 leading-5 text-sm transition-colors",
                  item.path === currentPath
                    ? "bg-muted font-medium text-foreground"
                    : "text-muted-foreground hover:bg-muted/50 hover:text-foreground",
                ]}
                href={item.url}
                data-mobile-nav-link
              >
                {item.title}
              </a>
            ))}
          </div>
        </div>
      ))}

      <div class="border-t border-border pt-5">
        <a
          class="flex w-full items-center rounded-md px-2 py-1.5 text-sm text-muted-foreground transition-colors hover:bg-muted/50 hover:text-foreground"
          href={product.githubUrl}
          rel="noreferrer"
          target="_blank"
          data-mobile-nav-link
        >
          GitHub
        </a>
      </div>
    </nav>
  </div>
</div>

<script>
  function setupMobileNav() {
    const trigger = document.querySelector<HTMLButtonElement>("[data-mobile-nav-trigger]")
    const panel = document.querySelector<HTMLElement>("[data-mobile-nav-panel]")
    if (!trigger || !panel) return

    const overlay = panel.querySelector<HTMLElement>("[data-mobile-nav-overlay]")
    const closeButton = panel.querySelector<HTMLButtonElement>("[data-mobile-nav-close]")
    const links = panel.querySelectorAll<HTMLAnchorElement>("[data-mobile-nav-link]")

    const open = () => {
      panel.classList.remove("hidden")
      trigger.setAttribute("aria-expanded", "true")
      document.body.style.overflow = "hidden"
    }

    const close = () => {
      panel.classList.add("hidden")
      trigger.setAttribute("aria-expanded", "false")
      document.body.style.overflow = ""
    }

    trigger.addEventListener("click", open)
    overlay?.addEventListener("click", close)
    closeButton?.addEventListener("click", close)
    links.forEach((link) => link.addEventListener("click", close))

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && !panel.classList.contains("hidden")) {
        close()
      }
    })
  }

  setupMobileNav()
  document.addEventListener("astro:after-swap", setupMobileNav)
</script>
