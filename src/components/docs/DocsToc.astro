---
import type { MarkdownHeading } from "astro";

type Props = {
  headings: MarkdownHeading[];
};

const { headings } = Astro.props;
const visibleHeadings = headings.filter((heading) => heading.depth > 1);
---

{
  visibleHeadings.length > 0 && (
    <nav class="docs-toc" aria-label="On this page">
      <p class="docs-toc-title">On this page</p>
      <ul class="docs-toc-list" role="list">
        {visibleHeadings.map((heading) => (
          <li
            class="docs-toc-item"
            style={`--toc-depth: ${Math.max(0, heading.depth - 2)};`}
          >
            <a
              href={`#${heading.slug}`}
              class="docs-toc-link"
              data-toc-link
              data-heading-slug={heading.slug}
            >
              <span class="docs-toc-link-indicator" aria-hidden="true"></span>
              <span class="docs-toc-link-text">{heading.text}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}
