---
import type { MarkdownHeading } from "astro";

type Props = {
  headings: MarkdownHeading[];
};

const { headings } = Astro.props;
const visibleHeadings = headings.filter((heading) => heading.depth > 1);
---

{
  visibleHeadings.length > 0 && (
    <div class="border-l border-border/70 pl-4">
      <p class="mb-3 text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-muted-foreground">
        On this page
      </p>

      <nav class="space-y-1">
        {
          visibleHeadings.map((heading) => (
            <a
              href={`#${heading.slug}`}
              class="block py-1 text-sm text-muted-foreground transition hover:text-foreground"
              style={`padding-left: ${Math.max(0, heading.depth - 2) * 0.85}rem;`}
            >
              {heading.text}
            </a>
          ))
        }
      </nav>
    </div>
  )
}
