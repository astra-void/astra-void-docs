---
import type { MarkdownHeading } from "astro";

type Props = {
  headings: MarkdownHeading[];
};

const { headings } = Astro.props;
const visibleHeadings = headings.filter((heading) => heading.depth > 1);
---

{
  visibleHeadings.length > 0 && (
    <div class="rounded-[calc(var(--radius)+0.25rem)] border border-border bg-card/90 p-4 shadow-sm">
      <p class="mb-3 text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground">
        On this page
      </p>

      <nav class="space-y-1.5">
        {
          visibleHeadings.map((heading) => (
            <a
              href={`#${heading.slug}`}
              class="block rounded-lg px-2 py-1.5 text-sm text-muted-foreground transition hover:bg-accent/10 hover:text-foreground"
              style={`padding-left: ${0.5 + Math.max(0, heading.depth - 2) * 0.85}rem;`}
            >
              {heading.text}
            </a>
          ))
        }
      </nav>
    </div>
  )
}
