---
import type { ResolvedPackageDocData } from "../../data/package-docs";

type Props = {
  doc: ResolvedPackageDocData;
};

const { doc } = Astro.props;

function escapeHtml(value: string) {
  return value
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#39;");
}

function formatInline(value: string) {
  return escapeHtml(value).replace(/`([^`]+)`/g, "<code>$1</code>");
}

function formatProvider(raw: string, optional: boolean) {
  return optional ? `${raw} (optional)` : raw;
}
---

<div class="package-doc">
  <section class="doc-section doc-section-overview">
    <div class="package-status-row">
      <span class:list={["package-status-badge", doc.maturity === "experimental" && "is-experimental"]}>
        {doc.maturityLabel}
      </span>
      <code class="package-install-name">{doc.npm}</code>
    </div>
    <p class="package-status-note" set:html={formatInline(doc.maturityNote)} />
  </section>

  <section class="doc-section doc-section-purpose">
    <h2 class="mb-4 text-2xl font-semibold tracking-[-0.04em] text-foreground">
      What It Is For
    </h2>
    {
      doc.whatItIsFor.map((paragraph) => (
        <p set:html={formatInline(paragraph)} />
      ))
    }
  </section>

  <section class="doc-section doc-section-install">
    <h2 class="mb-5 text-2xl font-semibold tracking-[-0.04em] text-foreground">
      Install
    </h2>

    <div class="install-grid">
      <div class="install-card">
        <h3>Global CLI</h3>
        <pre><code class="language-bash">{`lattice add ${doc.installName}`}</code></pre>
      </div>

      <div class="install-card">
        <h3>Monorepo Local Script</h3>
        <pre><code class="language-bash">{`pnpm lattice add ${doc.installName}`}</code></pre>
      </div>
    </div>

    <div class="package-meta-stack">
      <p>
        npm package: <code>{doc.npm}</code>
      </p>
      <div>
        <p>Peer dependencies</p>
        <ul class="export-list">
          {doc.peers.map((peer) => (
            <li>
              <code>{peer}</code>
            </li>
          ))}
        </ul>
      </div>
      {doc.providers.length > 0 && (
        <div>
          <p>Providers</p>
          <ul class="export-list">
            {doc.providers.map((provider) => (
              <li>
                <code>{formatProvider(provider.raw, provider.optional)}</code>
              </li>
            ))}
          </ul>
        </div>
      )}
      {doc.notes.length > 0 && (
        <div>
          <p>Registry notes</p>
          <ul class="state-list">
            {doc.notes.map((note) => <li set:html={formatInline(note)} />)}
          </ul>
        </div>
      )}
    </div>
  </section>

  <section class="doc-section doc-section-anatomy">
    <h2 class="mb-4 text-2xl font-semibold tracking-[-0.04em] text-foreground">
      Public Exports
    </h2>
    <ul class="export-list">
      {
        doc.exports.map((entry) => (
          <li>
            <code>{entry}</code>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="doc-section doc-section-state">
    <h2 class="mb-4 text-2xl font-semibold tracking-[-0.04em] text-foreground">
      State Model
    </h2>
    <ul class="state-list">
      {doc.stateModel.map((entry) => <li set:html={formatInline(entry)} />)}
    </ul>
  </section>

  <section class="doc-section doc-section-api">
    <h2 class="mb-5 text-2xl font-semibold tracking-[-0.04em] text-foreground">
      Key API
    </h2>
    <div class="api-grid">
      {
        doc.keyApi.map((entry) => (
          <div class="api-card">
            <h3>
              <code>{entry.name}</code>
            </h3>
            <p set:html={formatInline(entry.description)} />
          </div>
        ))
      }
    </div>
  </section>

  <section class="doc-section doc-section-patterns">
    <h2 class="mb-5 text-2xl font-semibold tracking-[-0.04em] text-foreground">
      Composition Patterns
    </h2>
    <div class="pattern-grid">
      {
        doc.compositionPatterns.map((entry) => (
          <div class="pattern-card">
            <h3>{entry.title}</h3>
            <p set:html={formatInline(entry.description)} />
          </div>
        ))
      }
    </div>
  </section>

  <section class="doc-section doc-section-cautions">
    <h2 class="mb-4 text-2xl font-semibold tracking-[-0.04em] text-foreground">
      Cautions / Limits
    </h2>
    <ul class="caution-list">
      {doc.cautions.map((entry) => <li set:html={formatInline(entry)} />)}
    </ul>
  </section>

  <section class="doc-section doc-section-related">
    <h2 class="mb-4 text-2xl font-semibold tracking-[-0.04em] text-foreground">
      Related
    </h2>
    <ul class="related-list">
      {
        doc.related.map((entry) => (
          <li>
            <a href={entry.href}>{entry.label}</a>
          </li>
        ))
      }
    </ul>
  </section>
</div>

