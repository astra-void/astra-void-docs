---
import { Code } from "astro:components";

type Props = {
  code: string;
  lang: string;
  meta?: string;
};

const { code, lang, meta } = Astro.props;
---

<div
  class="relative overflow-hidden rounded-xl border bg-card text-card-foreground shadow-sm"
>
  <Code code={code} lang={lang as any} meta={meta} class="docs-code-block" />
</div>
