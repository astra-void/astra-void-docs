---
type Props = {
  title: string;
  href: string;
  description: string;
};

const { title, href, description } = Astro.props;
---

<a href={href} class="docs-link-card group">
  <div>
    <h3 class="text-base font-semibold tracking-[-0.02em] text-card-foreground">{title}</h3>
    <p class="mt-2 text-sm leading-6 text-muted-foreground">{description}</p>
  </div>

  <span class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-border bg-background/75 text-muted-foreground transition group-hover:border-accent/30 group-hover:text-accent">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M5 12h14" />
      <path d="m12 5 7 7-7 7" />
    </svg>
  </span>
</a>
