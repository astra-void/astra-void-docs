---
import { resolvePackageManagerInstallInput } from "../../lib/package-manager-install";
import { PackageManagerInstallClient } from "./PackageManagerInstallClient";

const resolved = resolvePackageManagerInstallInput(
	Astro.props as Record<string, unknown>,
);
---

{
	resolved.managers.length > 0 && (
		<PackageManagerInstallClient
			client:load
			title={resolved.title}
			description={resolved.description}
			commands={resolved.commands}
			managers={resolved.managers}
			defaultManager={resolved.defaultManager}
		/>
	)
}
