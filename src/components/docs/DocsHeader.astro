---
import { ModeToggle } from "@/components/docs/ModeToggle"
import { SearchDialog } from "@/components/docs/SearchDialog"
import type { DocsProduct } from "@/lib/docs"

interface Props {
  product: DocsProduct
  docsHref: string
  componentsHref: string
  guidesHref: string
}

const { product, docsHref, componentsHref, guidesHref } = Astro.props as Props
---

<header
  class="sticky top-0 z-50 w-full border-b border-border bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60"
  transition:persist="docs-header"
>
  <div class="mx-auto flex h-14 max-w-screen-2xl items-center px-4 sm:px-6 lg:px-8">
    <div class="mr-4 flex min-w-0 items-center">
      <button
        type="button"
        class="-ml-1 mr-2 inline-flex h-9 w-9 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-muted/50 hover:text-foreground lg:hidden"
        aria-label="Open navigation"
        aria-expanded="false"
        aria-controls="docs-mobile-nav-panel"
        data-mobile-nav-trigger
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>

      <a class="mr-6 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground" href="/">
        Docs
      </a>

      <nav class="hidden items-center gap-5 text-sm md:flex">
        <a class="font-medium text-foreground" href={docsHref}>
          {product.title}
        </a>
        <a
          class="text-muted-foreground transition-colors hover:text-foreground"
          href={componentsHref}
        >
          Components
        </a>
        <a
          class="text-muted-foreground transition-colors hover:text-foreground"
          href={guidesHref}
        >
          Guides
        </a>
        <a
          class="text-muted-foreground transition-colors hover:text-foreground"
          href="/playground/"
        >
          Playground
        </a>
      </nav>
    </div>

    <div class="ml-auto flex items-center gap-2">
      <SearchDialog client:load />
      <a
        class="hidden text-sm text-muted-foreground transition-colors hover:text-foreground md:inline-flex"
        href={product.githubUrl}
        rel="noreferrer"
        target="_blank"
      >
        GitHub
      </a>
      <ModeToggle client:load />
    </div>
  </div>
</header>
