---
import { DOCS_SITE } from "../../lib/docs";
---

<header class="sticky top-0 z-30 border-b border-border/70 bg-background/92 backdrop-blur-sm">
  <div class="mx-auto flex h-14 max-w-[96rem] items-center gap-3 px-4 sm:px-6 lg:px-8">
    <button
      type="button"
      class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-border/60 text-muted-foreground transition hover:border-border hover:text-foreground lg:hidden"
      data-nav-toggle
      aria-controls="docs-sidebar"
      aria-expanded="false"
      aria-label="Open navigation"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
        <path d="M4 7h16" />
        <path d="M4 12h16" />
        <path d="M4 17h16" />
      </svg>
    </button>

    <a href="/" class="min-w-0 flex-1">
      <span class="block truncate text-xs font-medium uppercase tracking-[0.18em] text-muted-foreground">
        Lattice UI
      </span>
      <span class="block truncate text-base font-semibold tracking-[-0.03em] text-foreground">
        {DOCS_SITE.title}
      </span>
    </a>

    <div class="flex items-center gap-2">
      <a
        href={DOCS_SITE.githubUrl}
        class="docs-header-icon-button hidden sm:inline-flex"
        aria-label="Open GitHub repository"
        title="Open GitHub repository"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M12 .5C5.65.5.5 5.66.5 12.02c0 5.09 3.29 9.41 7.86 10.94.57.1.78-.25.78-.56 0-.27-.01-1.17-.02-2.12-3.2.7-3.88-1.36-3.88-1.36-.53-1.34-1.28-1.7-1.28-1.7-1.05-.72.08-.7.08-.7 1.16.08 1.78 1.2 1.78 1.2 1.03 1.77 2.69 1.26 3.35.97.1-.75.4-1.26.72-1.55-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.19-3.09-.12-.29-.52-1.47.11-3.06 0 0 .97-.31 3.17 1.18a10.9 10.9 0 0 1 5.77 0c2.19-1.49 3.16-1.18 3.16-1.18.63 1.59.23 2.77.11 3.06.74.8 1.19 1.83 1.19 3.09 0 4.42-2.69 5.39-5.26 5.67.41.36.78 1.07.78 2.16 0 1.56-.01 2.81-.01 3.2 0 .31.21.67.79.56a11.52 11.52 0 0 0 7.84-10.94C23.5 5.66 18.35.5 12 .5Z" />
        </svg>
      </a>

      <button
        type="button"
        class="docs-header-icon-button"
        data-theme-toggle
        aria-label="Switch to dark theme"
        title="Switch to dark theme"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4"
          data-theme-icon="sun"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2.5" />
          <path d="M12 19.5V22" />
          <path d="m4.93 4.93 1.77 1.77" />
          <path d="m17.3 17.3 1.77 1.77" />
          <path d="M2 12h2.5" />
          <path d="M19.5 12H22" />
          <path d="m4.93 19.07 1.77-1.77" />
          <path d="m17.3 6.7 1.77-1.77" />
        </svg>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4"
          data-theme-icon="moon"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path d="M12 3a6 6 0 0 0 9 9A9 9 0 1 1 12 3Z" />
        </svg>
      </button>
    </div>
  </div>
</header>
