---
import { DOCS_SITE } from "../../lib/docs";
---

<header class="sticky top-0 z-30 border-b border-border/80 bg-background/80 backdrop-blur-xl">
  <div class="mx-auto flex h-16 max-w-[96rem] items-center gap-3 px-4 sm:px-6 lg:px-8">
    <button
      type="button"
      class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-border bg-card text-card-foreground shadow-sm transition hover:border-accent/30 hover:text-accent lg:hidden"
      data-nav-toggle
      aria-controls="docs-sidebar"
      aria-expanded="false"
      aria-label="Open navigation"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
        <path d="M4 7h16" />
        <path d="M4 12h16" />
        <path d="M4 17h16" />
      </svg>
    </button>

    <a href="/" class="min-w-0 flex-1">
      <span class="block truncate text-sm font-medium uppercase tracking-[0.18em] text-accent">
        Lattice UI
      </span>
      <span class="block truncate text-base font-semibold tracking-[-0.03em] text-foreground">
        {DOCS_SITE.title}
      </span>
    </a>

    <div class="flex items-center gap-2">
      <a
        href={DOCS_SITE.githubUrl}
        class="hidden rounded-xl border border-border bg-card px-3 py-2 text-sm font-medium text-muted-foreground shadow-sm transition hover:border-accent/30 hover:text-foreground sm:inline-flex"
      >
        GitHub
      </a>

      <button
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-border bg-card text-card-foreground shadow-sm transition hover:border-accent/30 hover:text-accent"
        data-theme-toggle
        aria-label="Toggle theme"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4"
          data-theme-icon="sun"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
        >
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2.5" />
          <path d="M12 19.5V22" />
          <path d="m4.93 4.93 1.77 1.77" />
          <path d="m17.3 17.3 1.77 1.77" />
          <path d="M2 12h2.5" />
          <path d="M19.5 12H22" />
          <path d="m4.93 19.07 1.77-1.77" />
          <path d="m17.3 6.7 1.77-1.77" />
        </svg>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4"
          data-theme-icon="moon"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
        >
          <path d="M12 3a6 6 0 0 0 9 9A9 9 0 1 1 12 3Z" />
        </svg>
      </button>
    </div>
  </div>
</header>
