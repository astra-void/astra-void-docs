---
import { Button } from "../ui/button";
import { DOCS_SITE } from "../../lib/docs";

const normalizedPath = Astro.url.pathname.endsWith("/")
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;
const isComponentsPath = normalizedPath.startsWith("/components/");
const isPlaygroundPath = normalizedPath.startsWith("/playground/");
const isDocsPath = !isComponentsPath && !isPlaygroundPath;
const currentSectionLabel = isComponentsPath
  ? "Components"
  : isPlaygroundPath
    ? "Playground"
    : "Docs";

function navLinkClass(isActive: boolean) {
  return ["docs-header-nav-link", isActive ? "is-active" : undefined];
}
---

<header
  class="sticky top-0 z-50 w-full border-b border-border/40 bg-background/95 backdrop-blur supports-backdrop-filter:bg-background/60"
>
  <div
    class="container mx-auto flex h-14 max-w-screen-2xl items-center px-4 md:px-8"
  >
    <div class="mr-4 hidden md:flex">
      <a href="/" class="mr-6 flex items-center space-x-2">
        <span class="hidden font-bold sm:inline-block">
          {DOCS_SITE.title}
        </span>
      </a>
      <nav class="docs-header-nav flex items-center gap-1 text-sm font-medium">
        <a
          href="/"
          class:list={navLinkClass(isDocsPath)}
          aria-current={isDocsPath ? "page" : undefined}
          >Docs</a
        >
        <a
          href="/components/"
          class:list={navLinkClass(isComponentsPath)}
          aria-current={isComponentsPath ? "page" : undefined}
          >Components</a
        >
        <a
          href="/playground/"
          class:list={navLinkClass(isPlaygroundPath)}
          aria-current={isPlaygroundPath ? "page" : undefined}
          >Playground</a
        >
      </nav>
    </div>

    <Button
      type="button"
      variant="ghost"
      size="icon"
      className="mr-2 px-0 text-base hover:bg-transparent focus-visible:bg-transparent focus-visible:ring-0 focus-visible:ring-offset-0 md:hidden"
      data-nav-toggle
      aria-controls="docs-sidebar"
      aria-expanded="false"
      aria-label="Open navigation"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
      >
        <path d="M3 12h18M3 6h18M3 18h18"></path>
      </svg>
      <span class="sr-only">Toggle Menu</span>
    </Button>

    <div class="md:hidden flex min-w-0 flex-1 items-center gap-2">
      <a href="/" class="mr-6 flex items-center space-x-2">
        <span class="font-bold inline-block">
          {DOCS_SITE.title}
        </span>
      </a>
      <span
        class="docs-mobile-section-indicator"
        aria-label={`Current section: ${currentSectionLabel}`}
      >
        {currentSectionLabel}
      </span>
    </div>

    <div class="flex items-center justify-end gap-2 md:flex-1">
      <div class="hidden sm:block">
        <a
          href="/"
          class="docs-index-trigger inline-flex h-8 items-center gap-2 rounded-md border border-border/65 bg-muted/30 px-3 text-sm font-semibold text-foreground/85 no-underline transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
          aria-label="Open docs index"
          title="Open docs index"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-3.5 w-3.5 shrink-0 text-muted-foreground"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M4 6h16"></path>
            <path d="M4 12h16"></path>
            <path d="M4 18h10"></path>
          </svg>
          <span class="hidden lg:inline-flex">Open docs index</span>
          <span class="inline-flex lg:hidden">Docs index</span>
        </a>
      </div>
      <nav class="flex items-center">
        <a href={DOCS_SITE.githubUrl} target="_blank" rel="noreferrer">
          <div
            class="docs-header-icon-button inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 h-9 w-9"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="h-4 w-4"
            >
              <path
                d="M12 .5C5.65.5.5 5.66.5 12.02c0 5.09 3.29 9.41 7.86 10.94.57.1.78-.25.78-.56 0-.27-.01-1.17-.02-2.12-3.2.7-3.88-1.36-3.88-1.36-.53-1.34-1.28-1.7-1.28-1.7-1.05-.72.08-.7.08-.7 1.16.08 1.78 1.2 1.78 1.2 1.03 1.77 2.69 1.26 3.35.97.1-.75.4-1.26.72-1.55-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.19-3.09-.12-.29-.52-1.47.11-3.06 0 0 .97-.31 3.17 1.18a10.9 10.9 0 0 1 5.77 0c2.19-1.49 3.16-1.18 3.16-1.18.63 1.59.23 2.77.11 3.06.74.8 1.19 1.83 1.19 3.09 0 4.42-2.69 5.39-5.26 5.67.41.36.78 1.07.78 2.16 0 1.56-.01 2.81-.01 3.2 0 .31.21.67.79.56a11.52 11.52 0 0 0 7.84-10.94C23.5 5.66 18.35.5 12 .5Z"
              ></path>
            </svg>
            <span class="sr-only">GitHub</span>
          </div>
        </a>

        <Button
          type="button"
          variant="ghost"
          size="icon"
          data-theme-toggle
          aria-label="Toggle theme"
          className="docs-header-icon-button h-9 w-9"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-4 w-4 dark:-rotate-90 dark:scale-0 transition-all"
            data-theme-icon="sun"
            ><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2"
            ></path><path d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"
            ></path><path d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"
            ></path><path d="M20 12h2"></path><path d="m6.34 17.66-1.41 1.41"
            ></path><path d="m19.07 4.93-1.41 1.41"></path></svg
          >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="absolute h-4 w-4 rotate-90 scale-0 transition-all dark:rotate-0 dark:scale-100"
            data-theme-icon="moon"
            ><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path></svg
          >
          <span class="sr-only">Toggle theme</span>
        </Button>
      </nav>
    </div>
  </div>
</header>
