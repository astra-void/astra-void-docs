---
import { Badge } from "../ui/badge";
import { Card, CardContent } from "../ui/card";
import { packageDocs } from "../../data/package-docs";
import latticeSnapshot from "../../data/lattice-snapshot.generated";

type Props = {
  path: string;
  versionBasis: "main" | "stable";
};

const { path, versionBasis } = Astro.props;
const release = latticeSnapshot.workspace.changelog.latestRelease;
const componentSlug = path.startsWith("components/") ? path.slice("components/".length) : undefined;
const packageDoc = componentSlug ? packageDocs[componentSlug] : undefined;

function escapeHtml(value: string) {
  return value
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#39;");
}

function formatInline(value: string) {
  return escapeHtml(value).replace(/`([^`]+)`/g, "<code>$1</code>");
}

const sourceBadge =
  versionBasis === "stable" ? `Stable release v${release?.version ?? "n/a"}` : "Tracking lattice-ui/main";
const sourceMessage =
  versionBasis === "stable"
    ? "This page is written against the latest tagged release captured in the checked-in snapshot."
    : "This page is written against the checked-in snapshot of lattice-ui/main. Tagged releases can lag behind these docs.";
---

<Card className="border-muted/60 bg-card/80 shadow-sm backdrop-blur">
  <CardContent className="grid gap-4 p-4">
    <div class="flex flex-wrap gap-2">
      <Badge variant={versionBasis === "main" ? "default" : "secondary"}>{sourceBadge}</Badge>
      <Badge variant="outline">Latest tagged release: v{release?.version ?? "n/a"}</Badge>
      <Badge variant="outline">Snapshot date: {release?.date ?? "n/a"}</Badge>
      {
        packageDoc && (
          <Badge variant={packageDoc.maturity === "experimental" ? "secondary" : "outline"}>
            Package status: {packageDoc.maturityLabel}
          </Badge>
        )
      }
    </div>

    <div class="grid gap-2 text-sm leading-6 text-muted-foreground">
      <p>{sourceMessage}</p>
      {packageDoc && <p set:html={`Current package note: ${formatInline(packageDoc.maturityNote)}`} />}
    </div>
  </CardContent>
</Card>
