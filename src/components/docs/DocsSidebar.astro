---
import {
  isCurrentPath,
  isSectionActive,
  type DocPage,
  type SidebarSection,
} from "../../lib/docs";

type Props = {
  currentPath: string;
  homePage?: DocPage;
  sections: SidebarSection[];
};

const { currentPath, homePage, sections } = Astro.props;
const playgroundPath = "playground";
---

<div class="w-full">
  <div class="docs-sidebar-group pb-5">
    <h4 class="docs-sidebar-heading">Overview</h4>
    <div class="docs-sidebar-links">
      {
        homePage && (
          <a
            href={homePage.url}
            class:list={[
              "docs-sidebar-link",
              isCurrentPath(currentPath, homePage.path)
                ? "is-active"
                : undefined,
            ]}
            title={homePage.title}
            aria-current={isCurrentPath(currentPath, homePage.path)
              ? "page"
              : undefined}
          >
            <span class="docs-sidebar-link-label">{homePage.title}</span>
          </a>
        )
      }
      <a
        href="/playground/"
        class:list={[
          "docs-sidebar-link",
          isCurrentPath(currentPath, playgroundPath) ? "is-active" : undefined,
        ]}
        title="Playground"
        aria-current={isCurrentPath(currentPath, playgroundPath)
          ? "page"
          : undefined}
      >
        <span class="docs-sidebar-link-label">Playground</span>
      </a>
    </div>
  </div>

  {
    sections.map((section) => {
      const isSectionCurrent = isSectionActive(currentPath, section);
      const sectionPath =
        section.url && section.url !== "/" ? section.url.slice(1, -1) : "";
      const sectionAriaCurrent = isSectionCurrent
        ? isCurrentPath(currentPath, sectionPath)
          ? "page"
          : "location"
        : undefined;

      return (
        <div class="docs-sidebar-group pb-5">
          <h4 class="docs-sidebar-heading">
            {section.url ? (
              <a
                href={section.url}
                class:list={[
                  "docs-sidebar-heading-link",
                  isSectionCurrent ? "is-active" : undefined,
                ]}
                title={section.title}
                aria-current={sectionAriaCurrent}
              >
                {section.title}
              </a>
            ) : (
              section.title
            )}
          </h4>
          {section.entries.length > 0 && (
            <div class="docs-sidebar-links">
              {section.entries.map((entry) => (
                <a
                  href={entry.url}
                  class:list={[
                    "docs-sidebar-link",
                    isCurrentPath(currentPath, entry.path)
                      ? "is-active"
                      : undefined,
                  ]}
                  title={entry.title}
                  aria-current={isCurrentPath(currentPath, entry.path)
                    ? "page"
                    : undefined}
                >
                  <span class="docs-sidebar-link-label">{entry.title}</span>
                </a>
              ))}
            </div>
          )}
        </div>
      );
    })
  }
</div>
