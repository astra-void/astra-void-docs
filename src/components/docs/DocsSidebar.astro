---
import {
  isCurrentPath,
  type DocPage,
  type SidebarSection,
} from "../../lib/docs";

type Props = {
  currentPath: string;
  homePage?: DocPage;
  sections: SidebarSection[];
};

const { currentPath, homePage, sections } = Astro.props;
---

<div class="w-full">
  <div class="docs-sidebar-group pb-5">
    <h4 class="docs-sidebar-heading">Overview</h4>
    <div class="docs-sidebar-links">
      {
        homePage && (
          <a
            href={homePage.url}
            class:list={[
              "docs-sidebar-link",
              isCurrentPath(currentPath, homePage.path)
                ? "is-active"
                : undefined,
            ]}
            aria-current={isCurrentPath(currentPath, homePage.path)
              ? "page"
              : undefined}
          >
            <span class="docs-sidebar-link-label">{homePage.title}</span>
          </a>
        )
      }
    </div>
  </div>

  {
    sections.map((section) => (
      <div class="docs-sidebar-group pb-5">
        <h4 class="docs-sidebar-heading">
          {section.title}
        </h4>
        {section.entries.length > 0 && (
          <div class="docs-sidebar-links">
            {section.entries.map((entry) => (
              <a
                href={entry.url}
                class:list={[
                  "docs-sidebar-link",
                  isCurrentPath(currentPath, entry.path)
                    ? "is-active"
                    : undefined,
                ]}
                aria-current={isCurrentPath(currentPath, entry.path)
                  ? "page"
                  : undefined}
              >
                <span class="docs-sidebar-link-label">{entry.title}</span>
              </a>
            ))}
          </div>
        )}
      </div>
    ))
  }
</div>
