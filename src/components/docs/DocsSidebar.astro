---
import type { DocsProduct, DocsSectionGroup } from "@/lib/docs"

interface Props {
  sections: DocsSectionGroup[]
  currentPath: string
  product: DocsProduct
}

const { sections, currentPath, product } = Astro.props as Props
---

<aside class="hidden w-64 shrink-0 lg:block">
  <div class="sticky top-14 h-[calc(100vh-3.5rem)] overflow-y-auto py-8 pr-6">
    <nav class="space-y-7" aria-label={`${product.title} documentation`}>
      {sections.map((section) => (
        <div>
          <h4 class="mb-2 px-2 text-[0.8rem] font-medium text-muted-foreground">
            {section.label}
          </h4>
          <div class="grid grid-flow-row auto-rows-max text-sm">
            {section.items.map((item) => (
              <a
                aria-current={item.path === currentPath ? "page" : undefined}
                class:list={[
                  "group flex w-full items-center rounded-md px-2 py-1.5 leading-5 text-sm transition-colors",
                  item.path === currentPath
                    ? "bg-muted font-medium text-foreground"
                    : "text-muted-foreground hover:bg-muted/50 hover:text-foreground",
                ]}
                href={item.url}
              >
                {item.title}
              </a>
            ))}
          </div>
        </div>
      ))}
    </nav>
  </div>
</aside>
