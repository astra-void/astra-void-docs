---
import { Button } from "../ui/button";
import {
  isCurrentPath,
  isSectionActive,
  type DocPage,
  type SidebarSection,
} from "../../lib/docs";

type Props = {
  currentPath: string;
  homePage?: DocPage;
  sections: SidebarSection[];
};

const { currentPath, homePage, sections } = Astro.props;
---

<nav class="flex h-full flex-col gap-6 overflow-y-auto pr-2">
  {
    homePage && (
      <div class="grid gap-2">
        <p class="px-3 text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-muted-foreground">
          Overview
        </p>
        <Button
          asChild
          variant={isCurrentPath(currentPath, homePage.path) ? "secondary" : "ghost"}
          className="h-9 w-full justify-start px-3 font-medium"
        >
          <a href={homePage.url} title={homePage.title}>
            Home
          </a>
        </Button>
      </div>
    )
  }

  {
    sections.map((section) => (
      <section class="grid gap-2">
        <div class="flex items-center justify-between gap-3 px-3">
          {section.url ? (
            <a
              href={section.url}
              class:list={[
                "text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-muted-foreground transition hover:text-foreground",
                isSectionActive(currentPath, section) && "text-foreground",
              ]}
            >
              {section.title}
            </a>
          ) : (
            <p class="text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-muted-foreground">
              {section.title}
            </p>
          )}
        </div>

        <div class="grid gap-1">
          {
            section.entries.map((entry) => (
              <Button
                asChild
                variant={isCurrentPath(currentPath, entry.path) ? "secondary" : "ghost"}
                className="h-auto w-full justify-start px-3 py-2 text-left font-medium leading-5"
              >
                <a href={entry.url} title={entry.title}>
                  {entry.title}
                </a>
              </Button>
            ))
          }
        </div>
      </section>
    ))
  }
</nav>
