---
import { Card, CardContent, CardHeader, CardTitle } from "../ui/card";
import { Table, TableBody, TableHeader, TableRow } from "../ui/table";

type Props = {
  title?: string;
  columns: string[];
  rows: string[][];
};

const { title, columns, rows } = Astro.props;

function escapeHtml(value: string) {
  return value
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#39;");
}

function formatInline(value: string) {
  return escapeHtml(value)
    .replace(/`([^`]+)`/g, "<code>$1</code>")
    .replace(/\n/g, "<br />");
}
---

<Card className="my-8">
  {
    title && (
      <CardHeader className="pb-3">
        <CardTitle className="text-lg tracking-[-0.02em]">{title}</CardTitle>
      </CardHeader>
    )
  }
  <CardContent className="pb-6">
    <Table>
      <TableHeader>
        <TableRow>
          {
            columns.map((column) => (
              <th
                class="h-12 px-4 text-left align-middle font-medium text-muted-foreground"
                set:html={formatInline(column)}
              />
            ))
          }
        </TableRow>
      </TableHeader>
      <TableBody>
        {
          rows.map((row) => (
            <TableRow>
              {row.map((cell) => (
                <td class="p-4 align-middle" set:html={formatInline(cell)} />
              ))}
            </TableRow>
          ))
        }
      </TableBody>
    </Table>
  </CardContent>
</Card>
