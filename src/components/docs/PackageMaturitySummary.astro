---
import { Badge } from "../ui/badge";
import { Card, CardContent, CardHeader, CardTitle } from "../ui/card";
import latticeSnapshot from "../../data/lattice-snapshot.generated";

const foundationPackages = ["core", "focus", "layer", "style", "system"];
const stableFoundations =
  latticeSnapshot.workspace.stability.stableDirection.filter((slug) =>
    foundationPackages.includes(slug),
  );
const stableUiPackages =
  latticeSnapshot.workspace.stability.stableDirection.filter(
    (slug) => !foundationPackages.includes(slug),
  );
---

<div class="grid gap-4 md:grid-cols-2">
  <Card>
    <CardHeader>
      <CardTitle className="text-lg tracking-[-0.02em]"
        >Stable direction</CardTitle
      >
      <p class="text-sm leading-6 text-muted-foreground">
        These packages are the maintained path toward v1 and the default
        recommendation for product work.
      </p>
    </CardHeader>
    <CardContent className="grid gap-4">
      <div class="grid gap-2">
        <p class="text-sm font-medium text-foreground">Foundations</p>
        <div class="flex flex-wrap gap-2">
          {
            stableFoundations.map((slug) => (
              <Badge variant="outline">
                <code class="font-mono text-[0.8rem]">{slug}</code>
              </Badge>
            ))
          }
        </div>
      </div>
      <div class="grid gap-2">
        <p class="text-sm font-medium text-foreground">Primary UI packages</p>
        <div class="flex flex-wrap gap-2">
          {
            stableUiPackages.map((slug) => (
              <Badge variant="secondary">
                <code class="font-mono text-[0.8rem]">{slug}</code>
              </Badge>
            ))
          }
        </div>
      </div>
    </CardContent>
  </Card>

  <Card>
    <CardHeader>
      <CardTitle className="text-lg tracking-[-0.02em]"
        >Experimental / limited</CardTitle
      >
      <p class="text-sm leading-6 text-muted-foreground">
        These packages are available, but the docs should set expectations more
        narrowly.
      </p>
    </CardHeader>
    <CardContent>
      <ul class="grid gap-3">
        {
          latticeSnapshot.workspace.stability.experimental.map((entry) => (
            <li class="grid gap-1 rounded-lg border bg-muted/30 p-3">
              <strong class="text-sm font-semibold text-foreground">
                <code>{entry.slug}</code>
              </strong>
              <p class="text-sm leading-6 text-muted-foreground">
                {entry.note}
              </p>
            </li>
          ))
        }
      </ul>
    </CardContent>
  </Card>
</div>
