---
import CodeBlock from "./CodeBlock.astro";
import { LoomLiveDemoClient } from "./LoomLiveDemoClient";

interface Props {
	slug: string;
	sourceCode: string;
}

const { slug, sourceCode } = Astro.props;
const tabId = Math.random().toString(36).substring(2, 9);
---

<div
  class="group relative my-4 flex flex-col space-y-2 loom-demo-tabs"
  id={`demo-${tabId}`}
  data-preview-size="comfortable"
>
  <div class="relative mr-auto w-full">
    <div class="flex items-center justify-between pb-3">
      <div
        class="inline-flex h-9 items-center justify-center rounded-none border-b bg-transparent p-0 text-muted-foreground w-full"
        role="tablist"
        aria-label="Loom demo view"
      >
        <button
          type="button"
          id={`preview-tab-${tabId}`}
          role="tab"
          aria-selected="true"
          aria-controls={`preview-${tabId}`}
          tabindex="0"
          class="demo-tab-btn inline-flex items-center justify-center whitespace-nowrap px-4 pb-3 pt-2 text-sm font-semibold ring-offset-background transition-none focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 relative h-9 rounded-none border-b-2 border-b-transparent bg-transparent shadow-none data-[state=active]:border-b-primary data-[state=active]:text-foreground data-[state=active]:shadow-none"
          data-state="active"
          data-target={`preview-${tabId}`}
        >
          Preview
        </button>
        <button
          type="button"
          id={`code-tab-${tabId}`}
          role="tab"
          aria-selected="false"
          aria-controls={`code-${tabId}`}
          tabindex="-1"
          class="demo-tab-btn inline-flex items-center justify-center whitespace-nowrap px-4 pb-3 pt-2 text-sm font-semibold ring-offset-background transition-none focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 relative h-9 rounded-none border-b-2 border-b-transparent bg-transparent shadow-none data-[state=active]:border-b-primary data-[state=active]:text-foreground data-[state=active]:shadow-none"
          data-state="inactive"
          data-target={`code-${tabId}`}
        >
          Code
        </button>
      </div>
    </div>

    <div
      id={`preview-${tabId}`}
      role="tabpanel"
      tabindex="0"
      aria-labelledby={`preview-tab-${tabId}`}
      class="demo-tab-content demo-preview-panel mt-2 ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 relative rounded-md border"
    >
      <div class="demo-preview-toolbar">
        <span class="demo-preview-toolbar-label">Preview size</span>
        <div class="demo-preview-size-controls" role="group" aria-label="Preview size">
          <button
            type="button"
            class="demo-preview-size-btn"
            data-preview-size-control="compact"
            aria-pressed="false"
            title="Use compact preview"
          >
            Compact
          </button>
          <button
            type="button"
            class="demo-preview-size-btn is-active"
            data-preview-size-control="comfortable"
            aria-pressed="true"
            title="Use comfortable preview"
          >
            Comfortable
          </button>
          <button
            type="button"
            class="demo-preview-size-btn"
            data-preview-size-control="expanded"
            aria-pressed="false"
            title="Use expanded preview"
          >
            Expanded
          </button>
        </div>
      </div>
      <div class="preview demo-preview-stage">
        <LoomLiveDemoClient
          client:only="react"
          slug={slug}
          playgroundHref="/playground/"
        />
      </div>
    </div>

    <div
      id={`code-${tabId}`}
      role="tabpanel"
      tabindex="-1"
      aria-labelledby={`code-tab-${tabId}`}
      hidden
      class="demo-tab-content mt-2 ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
    >
      <div class="flex flex-col space-y-4">
        <div
          class="w-full rounded-md [&_pre]:my-0 [&_pre]:max-h-87.5 [&_pre]:overflow-auto"
        >
          <CodeBlock code={sourceCode} lang="tsx" />
        </div>
      </div>
    </div>

    <p class="mt-3 text-xs text-muted-foreground">
      Live demo is experimental and may contain bugs.
    </p>
  </div>
</div>

<script>
  (() => {
    const setupTabs = () => {
      const tabGroups = document.querySelectorAll(".loom-demo-tabs");

      tabGroups.forEach((group) => {
        if (!(group instanceof HTMLElement) || group.dataset.tabsReady === "true") {
          return;
        }

        const tabs = Array.from(group.querySelectorAll(".demo-tab-btn")).filter(
          (tab) => tab instanceof HTMLButtonElement,
        );

        if (tabs.length === 0) {
          return;
        }

        const previewSizeButtons = Array.from(
          group.querySelectorAll(".demo-preview-size-btn"),
        ).filter(
          (button) => button instanceof HTMLButtonElement,
        );

        const activatePreviewSize = (
          nextButton = previewSizeButtons[0],
          { focusButton = false } = {},
        ) => {
          if (!(nextButton instanceof HTMLButtonElement)) {
            return;
          }

          const nextSize = nextButton.dataset.previewSizeControl;
          if (!nextSize) {
            return;
          }

          group.dataset.previewSize = nextSize;

          previewSizeButtons.forEach((button) => {
            const isActive = button === nextButton;
            button.classList.toggle("is-active", isActive);
            button.setAttribute("aria-pressed", isActive ? "true" : "false");
          });

          if (focusButton) {
            nextButton.focus();
          }
        };

        const activateTab = (nextTab = tabs[0], { focusTab = false } = {}) => {
          if (!(nextTab instanceof HTMLButtonElement)) {
            return;
          }

          tabs.forEach((tab) => {
            const isActive = tab === nextTab;
            const panelId = tab.getAttribute("aria-controls");
            const panel = panelId ? document.getElementById(panelId) : null;

            tab.setAttribute("data-state", isActive ? "active" : "inactive");
            tab.setAttribute("aria-selected", isActive ? "true" : "false");
            tab.setAttribute("tabindex", isActive ? "0" : "-1");

            if (panel instanceof HTMLElement) {
              panel.hidden = !isActive;
              panel.setAttribute("tabindex", isActive ? "0" : "-1");
            }
          });

          if (focusTab) {
            nextTab.focus();
          }
        };

        const selectedTab =
          tabs.find((tab) => tab.getAttribute("aria-selected") === "true") ||
          tabs[0];
        activateTab(selectedTab);

        const selectedPreviewSizeButton =
          previewSizeButtons.find(
            (button) =>
              button.dataset.previewSizeControl === group.dataset.previewSize,
          ) ||
          previewSizeButtons.find(
            (button) => button.dataset.previewSizeControl === "comfortable",
          ) ||
          previewSizeButtons[0];

        if (selectedPreviewSizeButton) {
          activatePreviewSize(selectedPreviewSizeButton);
        }

        group.addEventListener("click", (event) => {
          const target = event.target;
          if (!(target instanceof Element)) {
            return;
          }

          const previewSizeButton = target.closest(".demo-preview-size-btn");
          if (
            previewSizeButton instanceof HTMLButtonElement &&
            previewSizeButtons.includes(previewSizeButton)
          ) {
            activatePreviewSize(previewSizeButton);
            return;
          }

          const tab = target.closest(".demo-tab-btn");
          if (!(tab instanceof HTMLButtonElement) || !tabs.includes(tab)) {
            return;
          }

          activateTab(tab);
        });

        group.addEventListener("keydown", (event) => {
          const target = event.target;

          if (
            target instanceof HTMLButtonElement &&
            previewSizeButtons.includes(target)
          ) {
            const currentIndex = previewSizeButtons.indexOf(target);
            let nextIndex = currentIndex;

            if (event.key === "ArrowRight") {
              nextIndex = (currentIndex + 1) % previewSizeButtons.length;
            } else if (event.key === "ArrowLeft") {
              nextIndex =
                (currentIndex - 1 + previewSizeButtons.length) %
                previewSizeButtons.length;
            } else if (event.key === "Home") {
              nextIndex = 0;
            } else if (event.key === "End") {
              nextIndex = previewSizeButtons.length - 1;
            } else {
              return;
            }

            event.preventDefault();
            activatePreviewSize(previewSizeButtons[nextIndex], {
              focusButton: true,
            });
            return;
          }

          if (!(target instanceof HTMLButtonElement) || !tabs.includes(target)) {
            return;
          }

          const currentIndex = tabs.indexOf(target);
          let nextIndex = currentIndex;

          if (event.key === "ArrowRight") {
            nextIndex = (currentIndex + 1) % tabs.length;
          } else if (event.key === "ArrowLeft") {
            nextIndex = (currentIndex - 1 + tabs.length) % tabs.length;
          } else if (event.key === "Home") {
            nextIndex = 0;
          } else if (event.key === "End") {
            nextIndex = tabs.length - 1;
          } else {
            return;
          }

          event.preventDefault();
          activateTab(tabs[nextIndex], { focusTab: true });
        });

        group.dataset.tabsReady = "true";
      });
    };

    setupTabs();

    if (document.documentElement.dataset.loomDemoTabsBound !== "true") {
      document.documentElement.dataset.loomDemoTabsBound = "true";
      document.addEventListener("astro:page-load", setupTabs);
    }
  })();
</script>
