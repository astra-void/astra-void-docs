---
import type { MarkdownHeading } from "astro";
import DocsHeader from "../components/docs/DocsHeader.astro";
import DocsPager from "../components/docs/DocsPager.astro";
import DocsSidebar from "../components/docs/DocsSidebar.astro";
import DocsToc from "../components/docs/DocsToc.astro";
import DocsVersionBanner from "../components/docs/DocsVersionBanner.astro";
import { DOCS_SITE, type DocPage, type SidebarSection } from "../lib/docs";
import "../styles/global.css";

type Props = {
  title: string;
  description: string;
  currentPage: DocPage;
  homePage?: DocPage;
  sections: SidebarSection[];
  headings: MarkdownHeading[];
  previousPage?: DocPage;
  nextPage?: DocPage;
};

const {
  title,
  description,
  currentPage,
  homePage,
  sections,
  headings,
  previousPage,
  nextPage,
} = Astro.props;

const pageTitle = currentPage.path
  ? `${title} | ${DOCS_SITE.title}`
  : DOCS_SITE.title;
const canonical = Astro.site ? new URL(currentPage.url, Astro.site) : undefined;
const hasToc = headings.some((heading) => heading.depth > 1);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description ?? DOCS_SITE.description} />
    {canonical && <link rel="canonical" href={canonical.toString()} />}
    <script is:inline>
      (() => {
        const storageKey = "lattice-ui-docs-theme";
        const root = document.documentElement;
        const storedTheme = window.localStorage.getItem(storageKey);
        const preferredTheme =
          storedTheme === "light" || storedTheme === "dark"
            ? storedTheme
            : window.matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light";

        root.dataset.theme = preferredTheme;
        root.classList.toggle("dark", preferredTheme === "dark");
      })();
    </script>
  </head>
  <body>
    <DocsHeader />

    <div
      class="docs-sidebar-overlay fixed inset-0 z-30 bg-background/60 lg:hidden"
      data-nav-close
      aria-hidden="true"
    />

    <div class="mx-auto flex max-w-[96rem] gap-8 px-4 pb-16 pt-8 sm:px-6 lg:px-8 xl:gap-12">
      <aside
        id="docs-sidebar"
        class="docs-sidebar-panel fixed inset-y-0 left-0 z-40 w-72 border-r border-border/80 bg-background px-5 py-6 lg:sticky lg:top-[4.75rem] lg:block lg:h-[calc(100vh-5.75rem)] lg:w-[16rem] lg:border-r lg:border-border/70 lg:bg-transparent"
      >
        <div class="mb-4 flex items-center justify-between gap-3 lg:hidden">
          <span class="text-sm font-semibold tracking-[-0.02em] text-foreground">
            Documentation
          </span>
          <button
            type="button"
            class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-border/70 text-muted-foreground"
            data-nav-close
            aria-label="Close navigation"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
              <path d="m18 6-12 12" />
              <path d="m6 6 12 12" />
            </svg>
          </button>
        </div>

        <DocsSidebar currentPath={currentPage.path} homePage={homePage} sections={sections} />
      </aside>

      <main class="min-w-0 flex-1">
        <div class="pb-10">
          <div class="max-w-3xl border-b border-border/70 pb-8">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground">
              {currentPage.sectionTitle}
            </p>
            <h1 class="mt-4 text-balance text-4xl font-semibold tracking-[-0.05em] text-foreground sm:text-5xl">
              {title}
            </h1>
            <p class="mt-4 max-w-2xl text-base leading-7 text-muted-foreground sm:text-lg">
              {description}
            </p>
            <div class="mt-6">
              <DocsVersionBanner path={currentPage.path} versionBasis={currentPage.versionBasis} />
            </div>
          </div>

          <article class="docs-prose mt-10 max-w-none">
            <slot />
          </article>

          <DocsPager previousPage={previousPage} nextPage={nextPage} />
        </div>
      </main>

      {
        hasToc && (
          <aside class="hidden w-64 shrink-0 xl:block">
            <div class="sticky top-[5.5rem]">
              <DocsToc headings={headings} />
            </div>
          </aside>
        )
      }
    </div>

    <script is:inline>
      (() => {
        const root = document.documentElement;
        const themeStorageKey = "lattice-ui-docs-theme";
        const themeToggleSelector = "[data-theme-toggle]";
        const codeCopyButtonSelector = "[data-copy-code]";
        let activeCopyFeedbackTimeout = 0;

        const applyTheme = (theme) => {
          root.dataset.theme = theme;
          root.classList.toggle("dark", theme === "dark");
          window.localStorage.setItem(themeStorageKey, theme);
          document.querySelectorAll(themeToggleSelector).forEach((toggle) => {
            if (!(toggle instanceof HTMLButtonElement)) {
              return;
            }

            const nextTheme = theme === "dark" ? "light" : "dark";
            toggle.setAttribute("aria-label", `Switch to ${nextTheme} theme`);
            toggle.setAttribute("title", `Switch to ${nextTheme} theme`);
          });
        };

        const resetCopyButtons = () => {
          document.querySelectorAll(codeCopyButtonSelector).forEach((button) => {
            if (!(button instanceof HTMLButtonElement)) {
              return;
            }

            button.dataset.copyState = "idle";
            button.setAttribute("aria-label", "Copy code to clipboard");
            button.setAttribute("title", "Copy code");
          });
        };

        const showCopyFeedback = (button, didCopy) => {
          window.clearTimeout(activeCopyFeedbackTimeout);
          resetCopyButtons();
          button.dataset.copyState = didCopy ? "done" : "error";
          button.setAttribute(
            "aria-label",
            didCopy ? "Code copied to clipboard" : "Failed to copy code to clipboard",
          );
          button.setAttribute("title", didCopy ? "Copied" : "Copy failed");

          activeCopyFeedbackTimeout = window.setTimeout(() => {
            button.dataset.copyState = "idle";
            button.setAttribute("aria-label", "Copy code to clipboard");
            button.setAttribute("title", "Copy code");
          }, 1800);
        };

        const copyText = async (value) => {
          if (navigator.clipboard?.writeText) {
            await navigator.clipboard.writeText(value);
            return true;
          }

          const selection = window.getSelection();
          const textArea = document.createElement("textarea");
          textArea.value = value;
          textArea.setAttribute("readonly", "true");
          textArea.style.position = "fixed";
          textArea.style.opacity = "0";
          document.body.append(textArea);
          textArea.select();
          const didCopy = document.execCommand("copy");
          textArea.remove();
          selection?.removeAllRanges();
          return didCopy;
        };

        const enhanceCodeBlocks = () => {
          document.querySelectorAll(".docs-prose pre").forEach((pre) => {
            if (!(pre instanceof HTMLPreElement) || pre.dataset.copyReady === "true") {
              return;
            }

            const code = pre.querySelector("code");
            if (!(code instanceof HTMLElement)) {
              return;
            }

            const button = document.createElement("button");
            button.type = "button";
            button.className = "docs-code-copy-button";
            button.dataset.copyCode = "true";
            button.dataset.copyState = "idle";
            button.setAttribute("aria-label", "Copy code to clipboard");
            button.setAttribute("title", "Copy code");
            button.innerHTML = `
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="docs-code-copy-icon docs-code-copy-icon-copy"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect x="9" y="9" width="13" height="13" rx="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
              </svg>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="docs-code-copy-icon docs-code-copy-icon-done"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M20 6 9 17l-5-5"></path>
              </svg>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="docs-code-copy-icon docs-code-copy-icon-error"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <circle cx="12" cy="12" r="9"></circle>
                <path d="M12 8v5"></path>
                <path d="M12 16h.01"></path>
              </svg>
            `;
            pre.append(button);
            pre.dataset.copyReady = "true";
          });
        };

        const closeNav = () => {
          delete root.dataset.navOpen;
          document
            .querySelector("[data-nav-toggle]")
            ?.setAttribute("aria-expanded", "false");
        };

        applyTheme(root.dataset.theme === "dark" ? "dark" : "light");
        enhanceCodeBlocks();

        document.addEventListener("click", async (event) => {
          const target = event.target;

          if (!(target instanceof Element)) {
            return;
          }

          const themeToggle = target.closest(themeToggleSelector);
          if (themeToggle) {
            const nextTheme = root.dataset.theme === "dark" ? "light" : "dark";
            applyTheme(nextTheme);
            return;
          }

          const codeCopyButton = target.closest(codeCopyButtonSelector);
          if (codeCopyButton instanceof HTMLButtonElement) {
            const pre = codeCopyButton.closest("pre");
            const code = pre?.querySelector("code");

            if (!(code instanceof HTMLElement)) {
              showCopyFeedback(codeCopyButton, false);
              return;
            }

            const copied = await copyText(code.innerText.replace(/\n$/, ""));
            showCopyFeedback(codeCopyButton, copied);
            return;
          }

          const exampleToggle = target.closest("[data-example-toggle]");
          if (exampleToggle instanceof HTMLButtonElement) {
            const example = exampleToggle.closest("[data-example-collapsible]");
            const panel = example?.querySelector("[data-example-panel]");

            if (!(example instanceof HTMLElement) || !(panel instanceof HTMLElement)) {
              return;
            }

            const nextOpen = example.dataset.open !== "true";
            example.dataset.open = nextOpen ? "true" : "false";
            exampleToggle.setAttribute("aria-expanded", nextOpen ? "true" : "false");
            panel.hidden = !nextOpen;
            return;
          }

          const navToggle = target.closest("[data-nav-toggle]");
          if (navToggle) {
            root.dataset.navOpen = root.dataset.navOpen === "true" ? "false" : "true";
            navToggle.setAttribute(
              "aria-expanded",
              root.dataset.navOpen === "true" ? "true" : "false",
            );
            return;
          }

          if (target.closest("[data-nav-close]") || target.closest("#docs-sidebar a")) {
            closeNav();
          }
        });

        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape") {
            closeNav();
          }
        });

        window.addEventListener("resize", () => {
          if (window.innerWidth >= 1024) {
            closeNav();
          }
        });
      })();
    </script>
  </body>
</html>
