---
import type { MarkdownHeading } from "astro";
import DocsHeader from "../components/docs/DocsHeader.astro";
import DocsPager from "../components/docs/DocsPager.astro";
import DocsSidebar from "../components/docs/DocsSidebar.astro";
import DocsToc from "../components/docs/DocsToc.astro";
import { DOCS_SITE, type DocPage, type SidebarSection } from "../lib/docs";
import "../styles/global.css";

type Props = {
	title: string;
	description: string;
	currentPage: DocPage;
	homePage?: DocPage;
	sections: SidebarSection[];
	headings: MarkdownHeading[];
	previousPage?: DocPage;
	nextPage?: DocPage;
};

const {
	title,
	description,
	currentPage,
	homePage,
	sections,
	headings,
	previousPage,
	nextPage,
} = Astro.props;

const pageTitle = currentPage.path
	? `${title} | ${DOCS_SITE.title}`
	: DOCS_SITE.title;
const canonical = Astro.site ? new URL(currentPage.url, Astro.site) : undefined;
const hasToc = headings.some((heading) => heading.depth > 1);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description ?? DOCS_SITE.description} />
    {canonical && <link rel="canonical" href={canonical.toString()} />}
    <script is:inline>
      (() => {
        const storageKey = "lattice-ui-docs-theme";
        const root = document.documentElement;
        const storedTheme = window.localStorage.getItem(storageKey);
        const preferredTheme =
          storedTheme === "light" || storedTheme === "dark"
            ? storedTheme
            : window.matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light";

        root.dataset.theme = preferredTheme;
        root.classList.toggle("dark", preferredTheme === "dark");
      })();
    </script>
  </head>
  <body>
    <DocsHeader />

    <div
      class="docs-sidebar-overlay fixed inset-0 z-30 bg-background/60 lg:hidden"
      data-nav-close
      aria-hidden="true"
    >
    </div>

    <div
      class="container mx-auto flex w-full max-w-380 flex-1 min-h-[calc(100dvh-3.5rem)] px-4 sm:px-6 lg:px-8 md:gap-8 lg:gap-12"
    >
      <aside
        id="docs-sidebar"
        class="docs-sidebar-panel fixed left-0 top-14 z-30 hidden h-[calc(100dvh-3.5rem)] w-full shrink-0 overflow-hidden border-r border-border/50 bg-sidebar/95 md:sticky md:block md:h-[calc(100dvh-3.5rem)] md:w-58 lg:w-62"
      >
        <div class="h-full overflow-y-auto overscroll-contain py-6 pr-5 lg:py-8">
          <DocsSidebar
            currentPath={currentPage.path}
            homePage={homePage}
            sections={sections}
          />
        </div>
      </aside>

      <main
        class="relative flex-1 min-w-0 py-7 md:py-9 xl:grid xl:grid-cols-[minmax(0,1fr)_17rem] xl:gap-11 2xl:grid-cols-[minmax(0,1fr)_18rem]"
      >
        <div class="mx-auto w-full min-w-0 max-w-200 md:pr-2">
          <div
            class="mb-4 flex items-center gap-1.5 text-[0.78rem] font-medium uppercase tracking-[0.12em] text-muted-foreground/85"
          >
            <div class="overflow-hidden text-ellipsis whitespace-nowrap">
              Docs
            </div>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="h-4 w-4"><path d="m9 18 6-6-6-6"></path></svg
            >
            <div class="font-medium text-foreground">
              {currentPage.sectionTitle}
            </div>
          </div>

          <div class="space-y-3 border-b border-border/55 pb-7">
            <h1 class="scroll-m-20 text-3xl font-bold tracking-[-0.035em] text-foreground sm:text-4xl">
              {title}
            </h1>
            <p class="max-w-[68ch] text-base leading-7 text-muted-foreground sm:text-[1.04rem]">
              {description}
            </p>
          </div>

          <article class="docs-prose max-w-none pb-14 pt-8 md:pt-9 *:last:mb-0">
            <slot />
          </article>

          <DocsPager previousPage={previousPage} nextPage={nextPage} />
        </div>

        {
          hasToc && (
            <div class="hidden text-sm xl:block">
              <div class="sticky top-20 pt-2">
                <DocsToc headings={headings} />
              </div>
            </div>
          )
        }
      </main>
    </div>

    <script is:inline>
      (() => {
        const root = document.documentElement;
        const themeStorageKey = "lattice-ui-docs-theme";
        const themeToggleSelector = "[data-theme-toggle]";
        const codeCopyButtonSelector = "[data-copy-code]";
        let cleanupTocTracking = () => {};
        let activeCopyFeedbackTimeout = 0;

        const applyTheme = (theme) => {
          root.dataset.theme = theme;
          root.classList.toggle("dark", theme === "dark");
          window.localStorage.setItem(themeStorageKey, theme);
          document.querySelectorAll(themeToggleSelector).forEach((toggle) => {
            if (!(toggle instanceof HTMLButtonElement)) {
              return;
            }

            const nextTheme = theme === "dark" ? "light" : "dark";
            toggle.setAttribute("aria-label", `Switch to ${nextTheme} theme`);
            toggle.setAttribute("title", `Switch to ${nextTheme} theme`);
          });
        };

        const resetCopyButtons = () => {
          document
            .querySelectorAll(codeCopyButtonSelector)
            .forEach((button) => {
              if (!(button instanceof HTMLButtonElement)) {
                return;
              }

              button.dataset.copyState = "idle";
              button.setAttribute("aria-label", "Copy code to clipboard");
              button.setAttribute("title", "Copy code");
            });
        };

        const showCopyFeedback = (button, didCopy) => {
          window.clearTimeout(activeCopyFeedbackTimeout);
          resetCopyButtons();
          button.dataset.copyState = didCopy ? "done" : "error";
          button.setAttribute(
            "aria-label",
            didCopy
              ? "Code copied to clipboard"
              : "Failed to copy code to clipboard",
          );
          button.setAttribute("title", didCopy ? "Copied" : "Copy failed");

          activeCopyFeedbackTimeout = window.setTimeout(() => {
            button.dataset.copyState = "idle";
            button.setAttribute("aria-label", "Copy code to clipboard");
            button.setAttribute("title", "Copy code");
          }, 1800);
        };

        const copyText = async (value) => {
          if (!navigator.clipboard?.writeText) {
            return false;
          }

          try {
            await navigator.clipboard.writeText(value);
            return true;
          } catch {
            return false;
          }
        };

        const enhanceCodeBlocks = () => {
          document.querySelectorAll(".docs-prose pre").forEach((pre) => {
            if (
              !(pre instanceof HTMLPreElement) ||
              pre.dataset.copyReady === "true"
            ) {
              return;
            }

            const code = pre.querySelector("code");
            if (!(code instanceof HTMLElement)) {
              return;
            }

            pre.classList.add("docs-code-pre");

            const button = document.createElement("button");
            button.type = "button";
            button.className = "docs-code-copy-button";
            button.dataset.copyCode = "true";
            button.dataset.copyState = "idle";
            button.setAttribute("aria-label", "Copy code to clipboard");
            button.setAttribute("title", "Copy code");
            button.innerHTML = `
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="docs-code-copy-icon docs-code-copy-icon-copy"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect x="9" y="9" width="13" height="13" rx="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
              </svg>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="docs-code-copy-icon docs-code-copy-icon-done"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M20 6 9 17l-5-5"></path>
              </svg>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="docs-code-copy-icon docs-code-copy-icon-error"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <circle cx="12" cy="12" r="9"></circle>
                <path d="M12 8v5"></path>
                <path d="M12 16h.01"></path>
              </svg>
            `;

            const codeSurface = pre.closest("[data-code-surface]");
            const actionSlot = codeSurface?.querySelector("[data-code-actions]");

            if (actionSlot instanceof HTMLElement) {
              button.classList.add("docs-code-copy-button-inline");
              actionSlot.append(button);
            } else {
              pre.classList.add("docs-code-pre-standalone");
              button.classList.add("docs-code-copy-button-floating");
              pre.append(button);
            }

            pre.dataset.copyReady = "true";
          });
        };

        const setupTocTracking = () => {
          cleanupTocTracking();

          const tocLinks = Array.from(
            document.querySelectorAll("[data-toc-link]"),
          ).filter((link) => link instanceof HTMLAnchorElement);

          if (tocLinks.length === 0) {
            return;
          }

          const pairs = tocLinks
            .map((link) => {
              if (!(link instanceof HTMLAnchorElement)) {
                return undefined;
              }

              const slug = link.dataset.headingSlug || link.hash.slice(1);
              const heading = slug ? document.getElementById(slug) : null;

              if (!(heading instanceof HTMLElement)) {
                return undefined;
              }

              return { link, heading };
            })
            .filter((pair) => pair !== undefined);

          if (pairs.length === 0) {
            return;
          }

          const syncToc = () => {
            const threshold = 140;
            let activePair = pairs[0];

            pairs.forEach((pair) => {
              if (pair.heading.getBoundingClientRect().top <= threshold) {
                activePair = pair;
              }
            });

            pairs.forEach((pair) => {
              if (pair === activePair) {
                pair.link.setAttribute("aria-current", "true");
                return;
              }

              pair.link.removeAttribute("aria-current");
            });
          };

          let ticking = false;
          const handleScroll = () => {
            if (ticking) {
              return;
            }

            ticking = true;
            window.requestAnimationFrame(() => {
              syncToc();
              ticking = false;
            });
          };

          window.addEventListener("scroll", handleScroll, { passive: true });
          window.addEventListener("resize", handleScroll);
          cleanupTocTracking = () => {
            window.removeEventListener("scroll", handleScroll);
            window.removeEventListener("resize", handleScroll);
          };
          syncToc();
        };

        const closeNav = () => {
          delete root.dataset.navOpen;
          document
            .querySelector("[data-nav-toggle]")
            ?.setAttribute("aria-expanded", "false");
        };

        applyTheme(root.dataset.theme === "dark" ? "dark" : "light");
        enhanceCodeBlocks();
        setupTocTracking();

        document.addEventListener("astro:page-load", () => {
          enhanceCodeBlocks();
          setupTocTracking();
        });

        document.addEventListener("astro:before-swap", () => {
          cleanupTocTracking();
        });

        document.addEventListener("click", async (event) => {
          const target = event.target;

          if (!(target instanceof Element)) {
            return;
          }

          const themeToggle = target.closest(themeToggleSelector);
          if (themeToggle) {
            const nextTheme = root.dataset.theme === "dark" ? "light" : "dark";
            applyTheme(nextTheme);
            return;
          }

          const codeCopyButton = target.closest(codeCopyButtonSelector);
          if (codeCopyButton instanceof HTMLButtonElement) {
            const pre = codeCopyButton.closest("pre");
            const code = pre?.querySelector("code");

            if (!(code instanceof HTMLElement)) {
              showCopyFeedback(codeCopyButton, false);
              return;
            }

            const copied = await copyText(code.innerText.replace(/\n$/, ""));
            showCopyFeedback(codeCopyButton, copied);
            return;
          }

          const exampleToggle = target.closest("[data-example-toggle]");
          if (exampleToggle instanceof HTMLButtonElement) {
            const example = exampleToggle.closest("[data-example-collapsible]");
            const panel = example?.querySelector("[data-example-panel]");

            if (
              !(example instanceof HTMLElement) ||
              !(panel instanceof HTMLElement)
            ) {
              return;
            }

            const nextOpen = example.dataset.open !== "true";
            example.dataset.open = nextOpen ? "true" : "false";
            exampleToggle.setAttribute(
              "aria-expanded",
              nextOpen ? "true" : "false",
            );
            panel.hidden = !nextOpen;
            return;
          }

          const navToggle = target.closest("[data-nav-toggle]");
          if (navToggle) {
            root.dataset.navOpen =
              root.dataset.navOpen === "true" ? "false" : "true";
            navToggle.setAttribute(
              "aria-expanded",
              root.dataset.navOpen === "true" ? "true" : "false",
            );
            return;
          }

          if (
            target.closest("[data-nav-close]") ||
            target.closest("#docs-sidebar a")
          ) {
            closeNav();
          }
        });

        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape") {
            closeNav();
          }
        });

        window.addEventListener("resize", () => {
          if (window.innerWidth >= 1024) {
            closeNav();
          }
        });
      })();
    </script>
  </body>
</html>
