---
import { getCollection, render } from "astro:content"
import { Code } from "astro-expressive-code/components"
import DocsCard from "@/components/docs/DocsCard.astro"
import DocsLayout from "@/layouts/DocsLayout.astro"
import {
  COMPONENT_GROUP_ORDER,
  DEFAULT_DOCS_PRODUCT,
  getDocPathFromId,
  getDocs,
} from "@/lib/docs"

const docs = await getCollection("docs")
const entry = docs.find((doc) => doc.id === "index")

if (!entry) {
  throw new Error("Missing docs home entry.")
}

const { Content } = await render(entry)
const currentPath = getDocPathFromId(entry.id, DEFAULT_DOCS_PRODUCT.id)

const navDocs = await getDocs(DEFAULT_DOCS_PRODUCT.id)

const componentGroups = COMPONENT_GROUP_ORDER.map((label) => ({
  label,
  items: navDocs.filter(
    (doc) => doc.section === "components" && doc.sidebarGroup === label,
  ),
})).filter((group) => group.items.length > 0)

const guides = navDocs.filter((doc) => doc.section === "guides")

const installationHref = getDocPathFromId(
  "getting-started/installation",
  DEFAULT_DOCS_PRODUCT.id,
)

const componentsHref = getDocPathFromId(
  "components/dialog",
  DEFAULT_DOCS_PRODUCT.id,
)

const stabilityHref = getDocPathFromId(
  "getting-started/package-stability",
  DEFAULT_DOCS_PRODUCT.id,
)

const heroCode = `<Dialog.Root>
  <Dialog.Trigger asChild>
    <textbutton Text="Invite player" />
  </Dialog.Trigger>
  <Dialog.Portal>
    <Dialog.Overlay />
    <Dialog.Content trapFocus restoreFocus>
      {/* your visuals */}
    </Dialog.Content>
  </Dialog.Portal>
</Dialog.Root>`

const pillars = [
  {
    title: "Headless primitives",
    description:
      "Keep rendering and styling in the app while Lattice owns the interaction contract.",
  },
  {
    title: "Focus and layers",
    description:
      "Restore focus, manage stacked overlays, and keep dismissal behavior predictable.",
  },
  {
    title: "App-owned visuals",
    description:
      "Build dialogs, selects, menus, and guided surfaces without moving visual ownership into the primitive layer.",
  },
] as const
---

<DocsLayout
  currentPath={currentPath}
  description={entry.data.description}
  productId={DEFAULT_DOCS_PRODUCT.id}
  title={entry.data.title}
>
  <div class="relative">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute -top-40 left-1/2 -z-10 h-72 w-[36rem] -translate-x-1/2 opacity-25 blur-3xl dark:opacity-15"
      style="background:
        radial-gradient(24rem 14rem at 30% 40%, #007cf0 0%, transparent 70%),
        radial-gradient(22rem 13rem at 65% 30%, #7928ca 0%, transparent 70%),
        radial-gradient(20rem 12rem at 80% 65%, #ff0080 0%, transparent 70%),
        radial-gradient(18rem 12rem at 45% 75%, #f9cb28 0%, transparent 70%);"
    >
    </div>

    <a
      class="inline-flex items-center gap-2 rounded-full border border-border bg-muted/50 px-3 py-1 font-mono text-xs text-muted-foreground transition-colors hover:text-foreground"
      href={stabilityHref}
    >
      <span
        aria-hidden="true"
        class="h-1.5 w-1.5 rounded-full bg-[#f5a623]"
      >
      </span>
      @lattice-ui · v0.5.0-next · pre-1.0
    </a>

    <div class="mt-6 flex flex-wrap gap-3">
      <a
        class="inline-flex h-10 items-center rounded-full bg-primary px-5 text-sm font-medium text-primary-foreground no-underline transition-opacity hover:opacity-90"
        href={installationHref}
      >
        Get started
      </a>
      <a
        class="inline-flex h-10 items-center rounded-full border border-border bg-card px-5 text-sm font-medium text-foreground no-underline transition-colors hover:bg-muted"
        href={componentsHref}
      >
        Browse components
      </a>
    </div>

    <div class="mt-8">
      <Content />
    </div>

    <div class="mt-8">
      <Code code={heroCode} lang="tsx" title="Behavior in, visuals yours." />
    </div>
  </div>

  <div class="mt-10 grid gap-3 sm:grid-cols-3">
    {pillars.map((pillar) => (
      <DocsCard title={pillar.title} description={pillar.description} />
    ))}
  </div>

  <section class="mt-14">
    <p class="font-mono text-xs uppercase tracking-wide text-muted-foreground">
      Components
    </p>
    <h2
      class="mt-2 text-2xl font-semibold tracking-[-0.04em] text-foreground"
    >
      {componentGroups.reduce((total, group) => total + group.items.length, 0)} primitives, one contract.
    </h2>
    <p class="mt-2 text-sm leading-6 text-muted-foreground">
      Every primitive shares the same composition model: compound parts,
      controlled or uncontrolled state, and <code
        class="rounded border border-border bg-muted px-1 py-0.5 font-mono text-[0.8em]"
        >asChild</code
      > composition.
    </p>

    {componentGroups.map((group) => (
      <div class="mt-8">
        <h3 class="font-mono text-xs uppercase tracking-wide text-muted-foreground">
          {group.label}
        </h3>
        <div class="mt-3 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {group.items.map((item) => (
            <DocsCard
              description={item.description}
              href={item.url}
              title={item.title}
            />
          ))}
        </div>
      </div>
    ))}
  </section>

  <section class="mt-14">
    <p class="font-mono text-xs uppercase tracking-wide text-muted-foreground">
      Guides
    </p>
    <h2 class="mt-2 text-2xl font-semibold tracking-[-0.04em] text-foreground">
      Learn the model once.
    </h2>
    <div class="mt-5 grid gap-3 sm:grid-cols-2">
      {guides.map((guide) => (
        <DocsCard
          description={guide.description}
          href={guide.url}
          title={guide.title}
        />
      ))}
    </div>
  </section>

  <section class="mt-14 rounded-xl border border-border bg-card p-6 shadow-card">
    <h2 class="text-lg font-semibold tracking-[-0.02em] text-foreground">
      Pre-1.0, moving deliberately.
    </h2>
    <p class="mt-2 text-sm leading-6 text-muted-foreground">
      Packages version in lockstep. Most primitives are stable in direction;
      Select and Slider are feature-limited, and Popper is experimental. Read
      the stability tiers before depending on an API.
    </p>
    <a
      class="mt-4 inline-flex text-sm font-medium text-link underline decoration-link/40 underline-offset-4 hover:decoration-link"
      href={stabilityHref}
    >
      Package stability →
    </a>
  </section>
</DocsLayout>
