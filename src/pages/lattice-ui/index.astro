---
import { render } from "astro:content";
import DocsLayout from "../../layouts/DocsLayout.astro";
import { getDocsShellData } from "../../lib/docs";
import { getDocsSiteTitle } from "../../lib/docs-sites";

const { currentPage, homePage, sections, previousPage, nextPage } =
	await getDocsShellData("", "/lattice-ui");
const siteTitle = getDocsSiteTitle(Astro.url.pathname);
const { Content, headings } = await render(currentPage.entry);
---

<DocsLayout
  title={currentPage.title}
  description={currentPage.description}
  siteTitle={siteTitle}
  currentPage={currentPage}
  homePage={homePage}
  sections={sections}
  headings={headings}
  previousPage={previousPage}
  nextPage={nextPage}
>
  <Content />
</DocsLayout>
