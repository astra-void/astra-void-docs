---
import { render } from "astro:content";
import DocsLayout from "../../layouts/DocsLayout.astro";
import { getDocsSiteTitle } from "../../lib/docs-sites";
import { getRbxtsTailwindDocsShellData } from "../../lib/rbxts-tailwind-docs";

const { currentPage, homePage, sections, previousPage, nextPage } =
	await getRbxtsTailwindDocsShellData("");
const siteTitle = getDocsSiteTitle(Astro.url.pathname);
const { Content, headings } = await render(currentPage.entry as never);
---

<DocsLayout
  title={currentPage.title}
  description={currentPage.description}
  siteTitle={siteTitle}
  currentPage={currentPage}
  homePage={homePage}
  sections={sections}
  headings={headings}
  previousPage={previousPage}
  nextPage={nextPage}
>
  <Content />
</DocsLayout>
