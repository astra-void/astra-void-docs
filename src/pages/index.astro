---
import DocsCard from "@/components/docs/DocsCard.astro"
import ThemeScript from "@/components/docs/ThemeScript.astro"
import { DOCS_PRODUCTS, DOCS_PRODUCT_ORDER } from "@/lib/docs"
import { ClientRouter } from "astro:transitions"
import "@/styles/global.css"

const products = DOCS_PRODUCT_ORDER.map((id) => DOCS_PRODUCTS[id])
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Documentation for astra-void projects."
    />
    <title>astra-void docs</title>
    <ClientRouter />
    <ThemeScript />
  </head>
  <body class="min-h-screen bg-background font-sans text-foreground antialiased">
    <main class="mx-auto flex min-h-screen w-full max-w-4xl flex-col justify-center px-4 py-16 sm:px-6 lg:px-8">
      <section class="max-w-2xl">
        <h1 class="scroll-m-20 text-4xl font-bold tracking-tight lg:text-5xl">
          astra-void docs
        </h1>
        <p class="mt-4 text-lg leading-8 text-muted-foreground">
          Documentation for astra-void projects.
        </p>
      </section>

      <section class="mt-10 grid max-w-2xl gap-3 sm:grid-cols-2">
        {products.map((product) => (
          <DocsCard
            title={product.title}
            description={product.description}
            href={product.href}
          />
        ))}
      </section>
    </main>
  </body>
</html>
