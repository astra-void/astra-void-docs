---
import PlaygroundWorkbenchClient from "../../components/docs/PlaygroundWorkbenchClient";
import { Badge } from "../../components/ui/badge";
import { Skeleton } from "../../components/ui/skeleton";
import DocsLayout from "../../layouts/DocsLayout.astro";
import { getDocsShellData } from "../../lib/docs";
import { getPlaygroundTemplates } from "../../lib/playground";

const docsShell = await getDocsShellData("");
const { homePage, sections } = docsShell;

if (!homePage) {
	throw new Error(
		"Home page metadata is required to build the playground route.",
	);
}

const templates = await getPlaygroundTemplates();
const currentPage = {
	...homePage,
	id: "playground/index",
	path: "playground",
	url: "/playground/",
	title: "Playground",
	description:
		"Edit starter examples inline and apply updates instantly to the live Loom preview.",
	sectionKey: "playground",
	sectionTitle: "Playground",
	sectionOrder: Number.MAX_SAFE_INTEGER,
	sidebarOrder: Number.MAX_SAFE_INTEGER,
	isSectionIndex: true,
};
---

<DocsLayout
	title={currentPage.title}
	description={currentPage.description}
	currentPage={currentPage}
	homePage={homePage}
	sections={sections}
	headings={[]}
>
	<section class="doc-section doc-section-overview">
		<div class="package-status-row">
			<Badge variant="outline" className="package-status-badge">Workbench</Badge>
			<code class="package-install-name">{templates.length} starter templates</code>
		</div>
		<p class="package-status-note">
			Choose a starter from src/examples/components, edit code directly, and
			watch the live preview update while you type. Loom preview is useful
			for iteration, but Roblox runtime verification remains the source of
			truth for final focus, input, layering, and motion behavior.
		</p>
	</section>

	<section class="doc-section">
		<PlaygroundWorkbenchClient client:only="react" templates={templates}>
			<div
				slot="fallback"
				class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_minmax(0,1fr)]"
			>
				<section class="space-y-3" aria-hidden="true">
					<div class="flex flex-wrap items-center gap-3">
						<Skeleton className="h-8 w-36" />
						<Skeleton className="h-8 w-28" />
						<Skeleton className="h-8 w-16" />
					</div>
					<Skeleton className="min-h-128 w-full border bg-muted/40" />
					<Skeleton className="h-4 w-52" />
				</section>

				<section class="space-y-3" role="status" aria-live="polite">
					<div class="flex items-center justify-between">
						<Skeleton className="h-4 w-24" />
						<Skeleton className="h-4 w-20" />
					</div>
					<div class="relative min-h-128 overflow-hidden rounded-md border bg-[#1e1e1e] p-4">
						<Skeleton className="h-4 w-40 bg-white/15" />
						<div class="mt-4 space-y-3">
							<Skeleton className="h-16 bg-white/10" />
							<Skeleton className="h-20 bg-white/10" />
							<Skeleton className="h-10 w-5/6 bg-white/10" />
						</div>
						<p class="mt-4 text-xs text-zinc-300/80">Preparing playground...</p>
					</div>
				</section>
			</div>
		</PlaygroundWorkbenchClient>
	</section>
</DocsLayout>
