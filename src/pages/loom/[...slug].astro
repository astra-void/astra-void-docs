---
import { getCollection, render } from "astro:content"
import DocsLayout from "@/layouts/DocsLayout.astro"
import { DOCS_PRODUCTS, getDocPathFromId, getDocSlug } from "@/lib/docs"

const PRODUCT_ID = "loom" as const

export async function getStaticPaths() {
  const productId = "loom" as const
  const docs = await getCollection("docs")

  return docs
    .filter(
      (doc) =>
        doc.data.product === productId &&
        !doc.data.draft &&
        getDocSlug(doc.id, productId) !== "",
    )
    .map((doc) => ({
      params: {
        slug: getDocSlug(doc.id, productId),
      },
      props: {
        id: doc.id,
        currentPath: getDocPathFromId(doc.id, productId),
      },
    }))
}

interface Props {
  id: string
  currentPath: string
}

const { id, currentPath } = Astro.props as Props
const docs = await getCollection("docs")
const entry = docs.find((doc) => doc.id === id)

if (!entry) {
  throw new Error(`Missing docs entry for ${id}.`)
}

const { Content, headings } = await render(entry)
---

<DocsLayout
  currentPath={currentPath}
  description={entry.data.description}
  headings={headings}
  productId={DOCS_PRODUCTS[PRODUCT_ID].id}
  title={entry.data.title}>
  <Content />
</DocsLayout>
