---
import { getCollection, render } from "astro:content"
import { Code } from "astro-expressive-code/components"
import DocsCard from "@/components/docs/DocsCard.astro"
import DocsLayout from "@/layouts/DocsLayout.astro"
import { getDocPathFromId, getDocs, getProductIndexId } from "@/lib/docs"

const PRODUCT_ID = "vela-rbxts" as const

const docs = await getCollection("docs")
const entry = docs.find((doc) => doc.id === getProductIndexId(PRODUCT_ID))

if (!entry) {
  throw new Error("Missing Vela docs home entry.")
}

const { Content } = await render(entry)
const currentPath = getDocPathFromId(entry.id, PRODUCT_ID)

const navDocs = await getDocs(PRODUCT_ID)

const guides = navDocs.filter((doc) => doc.section === "guides")
const reference = navDocs.filter((doc) => doc.section === "reference")

const installationHref = getDocPathFromId(
  "getting-started/installation",
  PRODUCT_ID,
)

const utilitiesHref = getDocPathFromId("reference/utilities", PRODUCT_ID)

const scopeHref = getDocPathFromId("getting-started/scope-and-status", PRODUCT_ID)

const heroCode = `<frame className="flex flex-col gap-4 p-4 w-80 rounded-lg bg-slate-800 border border-slate-700">
  <textlabel className="text-lg font-semibold text-slate-50" Text="Party" />
  <textbutton className="h-10 rounded-md bg-blue-600 text-white" Text="Invite" />
</frame>`

const pillars = [
  {
    title: "Compiled, not interpreted",
    description:
      "Static classes lower to Roblox props and helper instances during the roblox-ts build. No runtime cost, no generated folder.",
  },
  {
    title: "Roblox-shaped, not Tailwind-shaped",
    description:
      "Utilities map onto UIPadding, UIListLayout, UICorner, UIStroke, and the rest — the instances Roblox actually gives you.",
  },
  {
    title: "Loud about its gaps",
    description:
      "Unsupported families and unknown theme keys emit diagnostics instead of silently doing nothing.",
  },
] as const
---

<DocsLayout
  currentPath={currentPath}
  description={entry.data.description}
  productId={PRODUCT_ID}
  title={entry.data.title}
>
  <div class="relative">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute -top-40 left-1/2 -z-10 h-72 w-[36rem] -translate-x-1/2 opacity-25 blur-3xl dark:opacity-15"
      style="background:
        radial-gradient(24rem 14rem at 30% 40%, #007cf0 0%, transparent 70%),
        radial-gradient(22rem 13rem at 70% 35%, #00dfd8 0%, transparent 70%),
        radial-gradient(20rem 12rem at 55% 75%, #7928ca 0%, transparent 70%);"
    >
    </div>

    <a
      class="inline-flex items-center gap-2 rounded-full border border-border bg-muted/50 px-3 py-1 font-mono text-xs text-muted-foreground transition-colors hover:text-foreground"
      href={scopeHref}
    >
      <span aria-hidden="true" class="h-1.5 w-1.5 rounded-full bg-[#f5a623]"></span>
      vela-rbxts · v0.2.0 · pre-1.0
    </a>

    <div class="mt-6 flex flex-wrap gap-3">
      <a
        class="inline-flex h-10 items-center rounded-full bg-primary px-5 text-sm font-medium text-primary-foreground no-underline transition-opacity hover:opacity-90"
        href={installationHref}
      >
        Get started
      </a>
      <a
        class="inline-flex h-10 items-center rounded-full border border-border bg-card px-5 text-sm font-medium text-foreground no-underline transition-colors hover:bg-muted"
        href={utilitiesHref}
      >
        Utility reference
      </a>
    </div>

    {/* .docs-prose only spaces its direct children, and Content is nested here. */}
    <div class="mt-10 space-y-4">
      <Content />
    </div>

    <div class="mt-8">
      <Code code={heroCode} lang="tsx" title="className in, Roblox props out." />
    </div>
  </div>

  <div class="mt-10 grid gap-3 sm:grid-cols-3">
    {pillars.map((pillar) => (
      <DocsCard title={pillar.title} description={pillar.description} />
    ))}
  </div>

  <section class="mt-14">
    <p class="font-mono text-xs uppercase tracking-wide text-muted-foreground">
      Guides
    </p>
    <h2 class="mt-2 text-2xl font-semibold tracking-[-0.04em] text-foreground">
      Learn what lowers, and what doesn't.
    </h2>
    <div class="mt-5 grid gap-3 sm:grid-cols-2">
      {guides.map((guide) => (
        <DocsCard
          description={guide.description}
          href={guide.url}
          title={guide.title}
        />
      ))}
    </div>
  </section>

  <section class="mt-14">
    <p class="font-mono text-xs uppercase tracking-wide text-muted-foreground">
      Reference
    </p>
    <h2 class="mt-2 text-2xl font-semibold tracking-[-0.04em] text-foreground">
      Every class, value, and code.
    </h2>
    <div class="mt-5 grid gap-3 sm:grid-cols-2">
      {reference.map((item) => (
        <DocsCard
          description={item.description}
          href={item.url}
          title={item.title}
        />
      ))}
    </div>
  </section>

  <section class="mt-14 rounded-xl border border-border bg-card p-6 shadow-card">
    <h2 class="text-lg font-semibold tracking-[-0.02em] text-foreground">
      Pre-1.0, and narrow on purpose.
    </h2>
    <p class="mt-2 text-sm leading-6 text-muted-foreground">
      Packages version in lockstep. Whole Tailwind families are not implemented, a
      dynamic <code
        class="rounded border border-border bg-muted px-1 py-0.5 font-mono text-[0.8em]"
        >className</code
      > resolves against a much smaller utility set than a static one, and per-element
      restrictions are enforced by the editor rather than the compiler. Read the scope
      before you depend on a class.
    </p>
    <a
      class="mt-4 inline-flex text-sm font-medium text-link underline decoration-link/40 underline-offset-4 hover:decoration-link"
      href={scopeHref}
    >
      Scope and status →
    </a>
  </section>
</DocsLayout>
