---
import { render } from "astro:content";
import PackageDoc from "../components/docs/PackageDoc.astro";
import { resolvePackageDoc } from "../data/package-docs";
import DocsLayout from "../layouts/DocsLayout.astro";
import { getDocs, getDocsShellData } from "../lib/docs";

export async function getStaticPaths() {
  const docs = await getDocs();

  return docs
    .filter((doc) => doc.path)
    .map((doc) => ({
      params: {
        slug: doc.path,
      },
    }));
}

const currentPath = Astro.params.slug ?? "";
const { currentPage, homePage, sections, previousPage, nextPage } =
  await getDocsShellData(currentPath);
const { Content, headings } = await render(currentPage.entry);
const componentSlug = currentPath.startsWith("components/")
  ? currentPath.slice("components/".length)
  : undefined;
const packageDoc =
  componentSlug && currentPage.entry.data.packageDoc
    ? resolvePackageDoc(componentSlug, currentPage.entry.data.packageDoc)
    : undefined;
---

<DocsLayout
  title={currentPage.title}
  description={currentPage.description}
  currentPage={currentPage}
  homePage={homePage}
  sections={sections}
  headings={headings}
  previousPage={previousPage}
  nextPage={nextPage}
>
  <Content packageDoc={packageDoc} />
  {packageDoc && componentSlug && (
    <PackageDoc slug={componentSlug} doc={packageDoc} />
  )}
</DocsLayout>
